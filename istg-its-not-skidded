-- ════════════════════════════════════════════════════
--                  CREATE WINDOW
-- ════════════════════════════════════════════════════
function Library:CreateWindow(cfg)
    cfg = cfg or {}

    local W         = {}
    local ActiveTab = nil

    -- ── Main frame ───────────────────────────────
    local Main = F(C.Bg,
        UDim2.new(0, 760, 0, 520),
        UDim2.new(0.5, -380, 0.5, -260), SGui, false)
    Main.ZIndex = 10
    corner(14, Main)
    stroke(C.Border, 1.5, Main)
    shadow(Main, 44)

    -- ── INSERT to toggle visibility ───────────────
    UIS.InputBegan:Connect(function(i, gp)
        if gp then return end
        if i.KeyCode == Enum.KeyCode.Insert then
            Main.Visible = not Main.Visible
        end
    end)

    -- ── Drag (drag anywhere on Main) ─────────────
    do
        local drag, dStart, sPos
        Main.InputBegan:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 then
                drag = true; dStart = i.Position; sPos = Main.Position
            end
        end)
        UIS.InputChanged:Connect(function(i)
            if drag and i.UserInputType == Enum.UserInputType.MouseMovement then
                local d = i.Position - dStart
                Main.Position = UDim2.new(
                    sPos.X.Scale, sPos.X.Offset + d.X,
                    sPos.Y.Scale, sPos.Y.Offset + d.Y)
            end
        end)
        UIS.InputEnded:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 then drag = false end
        end)
    end

    -- ── Sidebar ──────────────────────────────────
    local Sidebar = F(C.Sidebar,
        UDim2.new(0, 196, 1, 0), nil, Main, true)
    Sidebar.ZIndex = 11
    corner(14, Sidebar)
    F(C.Sidebar, UDim2.new(0, 14, 1, 0),
        UDim2.new(1, -14, 0, 0), Sidebar).ZIndex = 11   -- fill right corners

    -- sidebar right divider
    F(C.SideDiv, UDim2.new(0, 1, 1, 0),
        UDim2.new(1, -1, 0, 0), Sidebar).ZIndex = 12

    -- ── Logo ─────────────────────────────────────
    local LogoBar = F(C.Sidebar, UDim2.new(1, 0, 0, 62), nil, Sidebar)
    LogoBar.ZIndex = 12
    pad(0, 18, 0, 18, LogoBar)

    -- pink accent dot
    local dot = F(C.Accent, UDim2.new(0, 8, 0, 8),
        UDim2.new(0, 0, 0.5, -4), LogoBar)
    dot.ZIndex = 13; corner(4, dot)

    L("Cuacker", Enum.Font.GothamBold, 17, C.TextPri,
        UDim2.new(1, -16, 0, 20),
        UDim2.new(0, 16, 0, 8), nil, LogoBar).ZIndex = 13
    L(cfg.Name or "Script", Enum.Font.Gotham, 10, C.TextSec,
        UDim2.new(1, -16, 0, 14),
        UDim2.new(0, 16, 0, 30), nil, LogoBar).ZIndex = 13

    -- divider under logo
    F(C.SideDiv, UDim2.new(1, -28, 0, 1),
        UDim2.new(0, 14, 1, -1), LogoBar).ZIndex = 12

    -- ── Nav scroll (fills entire sidebar below logo)
    local NavScroll = Instance.new("ScrollingFrame")
    NavScroll.Size                   = UDim2.new(1, 0, 1, -62)
    NavScroll.Position               = UDim2.new(0, 0, 0, 62)
    NavScroll.BackgroundTransparency = 1
    NavScroll.BorderSizePixel        = 0
    NavScroll.ScrollBarThickness     = 2
    NavScroll.ScrollBarImageColor3   = C.AccentMid
    NavScroll.CanvasSize             = UDim2.new(0, 0, 0, 0)
    NavScroll.AutomaticCanvasSize    = Enum.AutomaticSize.Y
    NavScroll.ZIndex                 = 12
    NavScroll.Parent                 = Sidebar
    pad(8, 10, 12, 10, NavScroll)
    vlist(3, NavScroll)

    -- ── Content pane ─────────────────────────────
    local ContentOuter = F(C.Bg,
        UDim2.new(1, -196, 1, 0),
        UDim2.new(0, 196, 0, 0), Main, true)
    ContentOuter.ZIndex = 11

    -- single scrolling tab content (no top bar)
    local TabContent = F(C.Bg,
        UDim2.new(1, 0, 1, 0), nil, ContentOuter, true)
    TabContent.ZIndex = 11

    -- ── Close button ─────────────────────────────
    local CloseBtn = F(C.AccentSoft, UDim2.new(0, 26, 0, 26),
        UDim2.new(1, -36, 0, 10), Main)
    CloseBtn.ZIndex = 30; corner(13, CloseBtn)
    local closeLbl = L("✕", Enum.Font.GothamBold, 11, C.Accent,
        UDim2.new(1, 0, 1, 0), nil, Enum.TextXAlignment.Center, CloseBtn)
    closeLbl.ZIndex = 31
    CloseBtn.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            Main.Visible = false
        end
    end)
    CloseBtn.MouseEnter:Connect(function()
        tw(CloseBtn, { BackgroundColor3 = C.Accent }, 0.1)
        tw(closeLbl, { TextColor3 = C.White }, 0.1)
    end)
    CloseBtn.MouseLeave:Connect(function()
        tw(CloseBtn, { BackgroundColor3 = C.AccentSoft }, 0.1)
        tw(closeLbl, { TextColor3 = C.Accent }, 0.1)
    end)

    -- ── Tab switcher ─────────────────────────────
    local function activateTab(tab)
        if ActiveTab then
            tw(ActiveTab._nav, { BackgroundColor3 = C.Sidebar }, 0.1)
            ActiveTab._navLbl.TextColor3 = C.TextSec
            ActiveTab._navLbl.Font       = Enum.Font.GothamMedium
            ActiveTab._navDot.BackgroundColor3 = C.Border
            ActiveTab._frame.Visible     = false
        end
        ActiveTab = tab
        tab._frame.Visible = true
        tw(tab._nav, { BackgroundColor3 = C.AccentSoft }, 0.12)
        tab._navLbl.TextColor3 = C.Accent
        tab._navLbl.Font       = Enum.Font.GothamBold
        tab._navDot.BackgroundColor3 = C.Accent
    end

    -- ════════════════════════════════════════════
    --               CREATE TAB
    -- ════════════════════════════════════════════
    function W:CreateTab(name, _icon)
        local tab = {}

        -- sidebar nav row
        local NavRow = F(C.Sidebar, UDim2.new(1, 0, 0, 36), nil, NavScroll)
        NavRow.ZIndex = 13; corner(8, NavRow)
        pad(0, 12, 0, 14, NavRow)

        local navDot = F(C.Border, UDim2.new(0, 7, 0, 7),
            UDim2.new(0, -1, 0.5, -3.5), NavRow)
        navDot.ZIndex = 14; corner(4, navDot)

        local navLbl = L(name, Enum.Font.GothamMedium, 12, C.TextSec,
            UDim2.new(1, -16, 1, 0), UDim2.new(0, 14, 0, 0), nil, NavRow)
        navLbl.ZIndex = 14

        -- content scrollframe
        local CF = Instance.new("ScrollingFrame")
        CF.Size                   = UDim2.new(1, 0, 1, 0)
        CF.BackgroundTransparency = 1
        CF.BorderSizePixel        = 0
        CF.ScrollBarThickness     = 3
        CF.ScrollBarImageColor3   = C.AccentMid
        CF.CanvasSize             = UDim2.new(0, 0, 0, 0)
        CF.AutomaticCanvasSize    = Enum.AutomaticSize.Y
        CF.ZIndex                 = 12
        CF.Visible                = false
        CF.Parent                 = TabContent
        pad(14, 18, 18, 18, CF)
        vlist(6, CF)

        tab._frame  = CF
        tab._nav    = NavRow
        tab._navLbl = navLbl
        tab._navDot = navDot

        NavRow.InputBegan:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 then activateTab(tab) end
        end)
        NavRow.MouseEnter:Connect(function()
            if ActiveTab ~= tab then
                tw(NavRow, { BackgroundColor3 = C.CardHover }, 0.08)
            end
        end)
        NavRow.MouseLeave:Connect(function()
            if ActiveTab ~= tab then
                tw(NavRow, { BackgroundColor3 = C.Sidebar }, 0.08)
            end
        end)

        if not ActiveTab then activateTab(tab) end

        -- ─── SECTION ─────────────────────────────
        function tab:CreateSection(title)
            local wrap = F(C.Bg, UDim2.new(1, 0, 0, 30), nil, CF)
            wrap.BackgroundTransparency = 1; wrap.ZIndex = 12
            L(title:upper(), Enum.Font.GothamBold, 9, C.TextMute,
                UDim2.new(1, 0, 0, 16), UDim2.new(0, 2, 0, 6), nil, wrap).ZIndex = 13
            F(C.Border, UDim2.new(1, 0, 0, 1),
                UDim2.new(0, 0, 1, -1), wrap).ZIndex = 13
        end

        -- ─── LABEL ───────────────────────────────
        function tab:CreateLabel(text)
            local obj = {}
            local Row = F(C.Card, UDim2.new(1, 0, 0, 38), nil, CF)
            Row.ZIndex = 13; corner(9, Row); stroke(C.Border, 1, Row)
            pad(0, 14, 0, 14, Row)
            local lbl = L(text, Enum.Font.GothamMedium, 12, C.TextSec,
                UDim2.new(1, 0, 1, 0), nil, nil, Row)
            lbl.ZIndex = 14
            function obj:Set(t) lbl.Text = t end
            return obj
        end

        -- ─── TOGGLE ──────────────────────────────
        function tab:CreateToggle(cfg2)
            cfg2 = cfg2 or {}
            local obj = {}
            local val = cfg2.CurrentValue or false
            if cfg2.Flag then Library.Flags[cfg2.Flag] = val end

            local Row = F(val and C.AccentSoft or C.Card,
                UDim2.new(1, 0, 0, 60), nil, CF)
            Row.ZIndex = 13; corner(10, Row); stroke(C.Border, 1, Row)
            pad(0, 14, 0, 14, Row)

            L(cfg2.Name or "", Enum.Font.GothamBold, 13, C.TextPri,
                UDim2.new(1, -56, 0, 18), UDim2.new(0, 0, 0, 8), nil, Row).ZIndex = 14
            L(cfg2.Description or "Toggle this option.", Enum.Font.Gotham, 10, C.TextSec,
                UDim2.new(1, -56, 0, 15), UDim2.new(0, 0, 0, 30), nil, Row).ZIndex = 14

            local Pill = F(val and C.TogOn or C.TogOff,
                UDim2.new(0, 40, 0, 22), UDim2.new(1, -40, 0.5, -11), Row)
            Pill.ZIndex = 14; corner(11, Pill)
            local Dot = F(C.White, UDim2.new(0, 16, 0, 16),
                val and UDim2.new(1, -19, 0.5, -8) or UDim2.new(0, 3, 0.5, -8), Pill)
            Dot.ZIndex = 15; corner(8, Dot)

            local function setVal(v)
                val = v
                if cfg2.Flag then Library.Flags[cfg2.Flag] = v end
                tw(Pill, { BackgroundColor3 = v and C.TogOn or C.TogOff }, 0.16)
                tw(Dot,  { Position = v
                    and UDim2.new(1, -19, 0.5, -8)
                    or  UDim2.new(0, 3,   0.5, -8) }, 0.16)
                tw(Row,  { BackgroundColor3 = v and C.AccentSoft or C.Card }, 0.16)
                if cfg2.Callback then cfg2.Callback(v) end
            end

            Row.InputBegan:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 then setVal(not val) end
            end)
            Row.MouseEnter:Connect(function()
                if not val then tw(Row, { BackgroundColor3 = C.CardHover }, 0.1) end
            end)
            Row.MouseLeave:Connect(function()
                if not val then tw(Row, { BackgroundColor3 = C.Card }, 0.1) end
            end)

            function obj:Set(v) setVal(v) end
            return obj
        end

        -- ─── SLIDER ──────────────────────────────
        -- FIX: MouseEnter/Leave on the track disables/re-enables the
        --      parent ScrollingFrame so scrolling the wheel never moves the page.
        function tab:CreateSlider(cfg2)
            cfg2 = cfg2 or {}
            local obj  = {}
            local mn   = (cfg2.Range and cfg2.Range[1]) or 0
            local mx   = (cfg2.Range and cfg2.Range[2]) or 100
            local step = cfg2.Increment or 1
            local suf  = cfg2.Suffix or ""
            local val  = cfg2.CurrentValue or mn
            if cfg2.Flag then Library.Flags[cfg2.Flag] = val end

            local Row = F(C.Card, UDim2.new(1, 0, 0, 66), nil, CF)
            Row.ZIndex = 13; corner(10, Row); stroke(C.Border, 1, Row)
            pad(0, 14, 0, 14, Row)

            L(cfg2.Name or "", Enum.Font.GothamBold, 13, C.TextPri,
                UDim2.new(0.62, 0, 0, 18), UDim2.new(0, 0, 0, 6), nil, Row).ZIndex = 14

            local ValLbl = L(tostring(val) .. (suf~="" and " "..suf or ""),
                Enum.Font.GothamBold, 12, C.Accent,
                UDim2.new(0.38, 0, 0, 18), UDim2.new(0.62, 0, 0, 6),
                Enum.TextXAlignment.Right, Row)
            ValLbl.ZIndex = 14

            local Track = F(C.SliderBg, UDim2.new(1, 0, 0, 6),
                UDim2.new(0, 0, 0, 42), Row)
            Track.ZIndex = 14; corner(3, Track)

            local pct0 = (val - mn) / (mx - mn)
            local Fill  = F(C.Accent, UDim2.new(pct0, 0, 1, 0), nil, Track)
            Fill.ZIndex = 15; corner(3, Fill)

            local Thumb = F(C.White, UDim2.new(0, 16, 0, 16),
                UDim2.new(pct0, -8, 0.5, -8), Track)
            Thumb.ZIndex = 16; corner(8, Thumb)
            stroke(C.AccentMid, 2, Thumb)

            -- ── scroll-lock: while mouse is over the slider,
            --    disable the parent tab ScrollingFrame ──────
            Track.MouseEnter:Connect(function() CF.ScrollingEnabled = false end)
            Track.MouseLeave:Connect(function() CF.ScrollingEnabled = true  end)
            Row.MouseLeave:Connect(function()   CF.ScrollingEnabled = true  end)

            local function setVal(v)
                v = math.clamp(math.round((v - mn) / step) * step + mn, mn, mx)
                val = v
                if cfg2.Flag then Library.Flags[cfg2.Flag] = v end
                local p = (v - mn) / (mx - mn)
                Fill.Size      = UDim2.new(p, 0, 1, 0)
                Thumb.Position = UDim2.new(p, -8, 0.5, -8)
                ValLbl.Text    = tostring(v) .. (suf~="" and " "..suf or "")
                if cfg2.Callback then cfg2.Callback(v) end
            end

            local sliding = false
            Track.InputBegan:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 then
                    sliding = true
                    local rx = math.clamp(
                        (i.Position.X - Track.AbsolutePosition.X)
                        / Track.AbsoluteSize.X, 0, 1)
                    setVal(mn + rx * (mx - mn))
                end
            end)
            UIS.InputChanged:Connect(function(i)
                if sliding and i.UserInputType == Enum.UserInputType.MouseMovement then
                    local rx = math.clamp(
                        (i.Position.X - Track.AbsolutePosition.X)
                        / Track.AbsoluteSize.X, 0, 1)
                    setVal(mn + rx * (mx - mn))
                end
            end)
            UIS.InputEnded:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 then
                    sliding = false
                    CF.ScrollingEnabled = true
                end
            end)

            function obj:Set(v) setVal(v) end
            return obj
        end

        -- ─── KEYBIND ─────────────────────────────
        -- • Left-click  → listen for new key
        -- • Same key again while already bound → sets to "None" (Keyless)
        -- • Right-click → context menu: Toggle / Hold / Keyless
        function tab:CreateKeybind(cfg2)
            cfg2 = cfg2 or {}
            local obj       = {}
            local curKey    = cfg2.CurrentKeybind or "None"
            local mode      = "Toggle"
            local listening = false
            local held      = false
            if cfg2.Flag then Library.Flags[cfg2.Flag] = curKey end

            local Row = F(C.Card, UDim2.new(1, 0, 0, 72), nil, CF)
            Row.ZIndex = 13; corner(10, Row); stroke(C.Border, 1, Row)
            pad(0, 14, 0, 14, Row)

            L(cfg2.Name or "", Enum.Font.GothamBold, 13, C.TextPri,
                UDim2.new(1, -120, 0, 18), UDim2.new(0, 0, 0, 7), nil, Row).ZIndex = 14
            L("Left-click to bind  ·  Right-click for options",
                Enum.Font.Gotham, 10, C.TextMute,
                UDim2.new(1, -120, 0, 14), UDim2.new(0, 0, 0, 29), nil, Row).ZIndex = 14

            -- mode badge
            local ModeBadge = F(C.AccentSoft, UDim2.new(0, 56, 0, 19),
                UDim2.new(1, -116, 0, 48), Row)
            ModeBadge.ZIndex = 14; corner(5, ModeBadge)
            local ModeLbl = L("Toggle", Enum.Font.GothamBold, 9, C.Accent,
                UDim2.new(1, 0, 1, 0), nil, Enum.TextXAlignment.Center, ModeBadge)
            ModeLbl.ZIndex = 15

            -- key badge
            local KeyBadge = F(C.BadgeBg, UDim2.new(0, 52, 0, 28),
                UDim2.new(1, -56, 0.5, -14), Row)
            KeyBadge.ZIndex = 14; corner(7, KeyBadge)
            local kstr = stroke(C.Border, 1.5, KeyBadge)

            local KeyLbl = L(curKey == "None" and "None" or curKey:upper():sub(1, 7),
                Enum.Font.GothamBold, 11, C.TextPri,
                UDim2.new(1, 0, 1, 0), nil, Enum.TextXAlignment.Center, KeyBadge)
            KeyLbl.ZIndex = 15

            local function refreshBadge()
                ModeLbl.Text = mode
                if listening then
                    KeyLbl.Text       = "..."
                    KeyLbl.TextColor3 = C.Accent
                    tw(KeyBadge, { BackgroundColor3 = C.AccentSoft })
                    kstr.Color = C.Accent
                elseif curKey == "None" then
                    KeyLbl.Text       = "None"
                    KeyLbl.TextColor3 = C.TextMute
                    tw(KeyBadge, { BackgroundColor3 = C.BadgeBg })
                    kstr.Color = C.Border
                else
                    KeyLbl.Text       = curKey:upper():sub(1, 7)
                    KeyLbl.TextColor3 = C.TextPri
                    tw(KeyBadge, { BackgroundColor3 = C.BadgeBg })
                    kstr.Color = C.Border
                end
            end

            -- left / right click on badge
            KeyBadge.InputBegan:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 then
                    listening = true
                    refreshBadge()
                elseif i.UserInputType == Enum.UserInputType.MouseButton2 then
                    local ap = KeyBadge.AbsolutePosition
                    showCtx({
                        { label = "Toggle",
                          active = (mode == "Toggle"),
                          callback = function() mode = "Toggle"; refreshBadge() end },
                        { label = "Hold",
                          active = (mode == "Hold"),
                          callback = function() mode = "Hold";   refreshBadge() end },
                        { label = "Keyless  (unbind)",
                          active = (curKey == "None"),
                          callback = function()
                              curKey = "None"; listening = false
                              if cfg2.Flag then Library.Flags[cfg2.Flag] = "None" end
                              refreshBadge()
                          end },
                    }, ap.X, ap.Y + 32)
                end
            end)
            KeyBadge.MouseEnter:Connect(function()
                if not listening then tw(KeyBadge, { BackgroundColor3 = C.AccentSoft }, 0.1) end
            end)
            KeyBadge.MouseLeave:Connect(function()
                if not listening then tw(KeyBadge, { BackgroundColor3 = C.BadgeBg }, 0.1) end
            end)

            -- keyboard input
            UIS.InputBegan:Connect(function(i, gp)
                if gp then return end
                if i.UserInputType ~= Enum.UserInputType.Keyboard then return end
                if i.KeyCode == Enum.KeyCode.Insert then return end  -- reserved

                if listening then
                    listening = false
                    local k = i.KeyCode.Name
                    -- pressing same key again → Keyless
                    if k == curKey then
                        curKey = "None"
                    else
                        curKey = k
                    end
                    if cfg2.Flag then Library.Flags[cfg2.Flag] = curKey end
                    refreshBadge()
                    return
                end

                if curKey ~= "None" and i.KeyCode.Name == curKey then
                    if mode == "Toggle" then
                        if cfg2.Callback then cfg2.Callback() end
                    elseif mode == "Hold" then
                        held = true
                        if cfg2.Callback then cfg2.Callback(true) end
                    end
                end
            end)

            UIS.InputEnded:Connect(function(i)
                if mode == "Hold" and held
                and i.UserInputType == Enum.UserInputType.Keyboard
                and curKey ~= "None" and i.KeyCode.Name == curKey then
                    held = false
                    if cfg2.Callback then cfg2.Callback(false) end
                end
            end)

            function obj:Set(k)
                curKey = k or "None"
                if cfg2.Flag then Library.Flags[cfg2.Flag] = curKey end
                refreshBadge()
            end
            function obj:SetMode(m) mode = m or "Toggle"; refreshBadge() end
            return obj
        end

        -- ─── BUTTON ──────────────────────────────
        function tab:CreateButton(cfg2)
            cfg2 = cfg2 or {}
            local obj = {}
            local Row = F(C.Card, UDim2.new(1, 0, 0, 50), nil, CF)
            Row.ZIndex = 13; corner(10, Row); stroke(C.Border, 1, Row)
            pad(0, 14, 0, 14, Row)

            local Btn = F(C.Accent, UDim2.new(1, 0, 0, 28),
                UDim2.new(0, 0, 0.5, -14), Row)
            Btn.ZIndex = 14; corner(8, Btn)

            L(cfg2.Name or "Button", Enum.Font.GothamBold, 12, C.White,
                UDim2.new(1, 0, 1, 0), nil, Enum.TextXAlignment.Center, Btn).ZIndex = 15

            Btn.InputBegan:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 then
                    tw(Btn, { Size = UDim2.new(0.97, 0, 0, 26) }, 0.07)
                    task.delay(0.1, function()
                        tw(Btn, { Size = UDim2.new(1, 0, 0, 28) }, 0.1)
                    end)
                    if cfg2.Callback then cfg2.Callback() end
                end
            end)
            Btn.MouseEnter:Connect(function()
                tw(Btn, { BackgroundColor3 = C.AccentDark }, 0.1)
            end)
            Btn.MouseLeave:Connect(function()
                tw(Btn, { BackgroundColor3 = C.Accent }, 0.1)
            end)

            function obj:Set() end
            return obj
        end

        -- ─── INPUT ───────────────────────────────
        function tab:CreateInput(cfg2)
            cfg2 = cfg2 or {}
            local obj = {}
            local Row = F(C.Card, UDim2.new(1, 0, 0, 64), nil, CF)
            Row.ZIndex = 13; corner(10, Row); stroke(C.Border, 1, Row)
            pad(0, 14, 0, 14, Row)

            L(cfg2.Name or "", Enum.Font.GothamBold, 13, C.TextPri,
                UDim2.new(1, 0, 0, 17), UDim2.new(0, 0, 0, 5), nil, Row).ZIndex = 14

            local IBg = F(C.SliderBg, UDim2.new(1, 0, 0, 26),
                UDim2.new(0, 0, 0, 30), Row)
            IBg.ZIndex = 14; corner(6, IBg)
            local ist = stroke(C.Border, 1, IBg)

            local TBox = Instance.new("TextBox")
            TBox.Size               = UDim2.new(1, -16, 1, 0)
            TBox.Position           = UDim2.new(0, 8, 0, 0)
            TBox.BackgroundTransparency = 1
            TBox.Text               = cfg2.CurrentValue or ""
            TBox.PlaceholderText    = cfg2.PlaceholderText or "Type here…"
            TBox.Font               = Enum.Font.Gotham
            TBox.TextSize           = 11
            TBox.TextColor3         = C.TextPri
            TBox.PlaceholderColor3  = C.TextMute
            TBox.TextXAlignment     = Enum.TextXAlignment.Left
            TBox.BorderSizePixel    = 0
            TBox.ZIndex             = 15
            TBox.Parent             = IBg
            TBox.Focused:Connect(function()
                tw(IBg, { BackgroundColor3 = C.AccentSoft }, 0.1)
                ist.Color = C.Accent
            end)
            TBox.FocusLost:Connect(function(enter)
                tw(IBg, { BackgroundColor3 = C.SliderBg }, 0.1)
                ist.Color = C.Border
                if cfg2.Flag then Library.Flags[cfg2.Flag] = TBox.Text end
                if cfg2.Callback then cfg2.Callback(TBox.Text, enter) end
            end)
            function obj:Set(v) TBox.Text = v end
            return obj
        end

        -- ─── DROPDOWN ────────────────────────────
        function tab:CreateDropdown(cfg2)
            cfg2 = cfg2 or {}
            local obj     = {}
            local options = cfg2.Options or {}
            local sel     = cfg2.CurrentOption or (options[1] or "Select…")
            local open    = false
            if cfg2.Flag then Library.Flags[cfg2.Flag] = sel end

            local Row = F(C.Card, UDim2.new(1, 0, 0, 62), nil, CF)
            Row.ZIndex = 13; corner(10, Row); stroke(C.Border, 1, Row)
            pad(0, 14, 0, 14, Row)

            L(cfg2.Name or "", Enum.Font.GothamBold, 13, C.TextPri,
                UDim2.new(1, 0, 0, 17), UDim2.new(0, 0, 0, 4), nil, Row).ZIndex = 14

            local DBg = F(C.SliderBg, UDim2.new(1, 0, 0, 26),
                UDim2.new(0, 0, 0, 28), Row)
            DBg.ZIndex = 14; corner(6, DBg); stroke(C.Border, 1, DBg)

            local SelLbl = L(tostring(sel), Enum.Font.GothamMedium, 11, C.TextPri,
                UDim2.new(1, -26, 1, 0), UDim2.new(0, 8, 0, 0), nil, DBg)
            SelLbl.ZIndex = 15
            L("⌄", Enum.Font.GothamBold, 13, C.TextSec,
                UDim2.new(0, 20, 1, 0), UDim2.new(1, -22, 0, 0),
                Enum.TextXAlignment.Center, DBg).ZIndex = 15

            local DList = F(C.Card, UDim2.new(1, 0, 0, 0),
                UDim2.new(0, 0, 1, 4), Row, true)
            DList.ZIndex = 60; corner(8, DList); stroke(C.Border, 1, DList)
            vlist(0, DList)

            local function buildList()
                for _, c2 in ipairs(DList:GetChildren()) do
                    if c2:IsA("Frame") then c2:Destroy() end
                end
                for _, opt in ipairs(options) do
                    local active = tostring(opt) == tostring(sel)
                    local OR = F(active and C.AccentSoft or C.Card,
                        UDim2.new(1, -8, 0, 28), nil, DList)
                    OR.ZIndex = 61; corner(5, OR); pad(0, 10, 0, 10, OR)
                    local oLbl = L(tostring(opt), Enum.Font.GothamMedium, 11,
                        active and C.Accent or C.TextPri,
                        UDim2.new(1, 0, 1, 0), nil, nil, OR)
                    oLbl.ZIndex = 62
                    OR.InputBegan:Connect(function(i)
                        if i.UserInputType == Enum.UserInputType.MouseButton1 then
                            sel = opt; SelLbl.Text = tostring(opt)
                            if cfg2.Flag then Library.Flags[cfg2.Flag] = opt end
                            if cfg2.Callback then cfg2.Callback(opt) end
                            open = false
                            tw(DList, { Size = UDim2.new(1, 0, 0, 0) })
                            Row.Size = UDim2.new(1, 0, 0, 62)
                            buildList()
                        end
                    end)
                    OR.MouseEnter:Connect(function()
                        if not active then tw(OR, { BackgroundColor3 = C.AccentSoft }, 0.08) end
                    end)
                    OR.MouseLeave:Connect(function()
                        if not active then tw(OR, { BackgroundColor3 = C.Card }, 0.08) end
                    end)
                end
            end
            buildList()

            DBg.InputBegan:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 then
                    open = not open
                    local h = open and math.min(#options, 6) * 28 or 0
                    tw(DList, { Size = UDim2.new(1, 0, 0, h) })
                    Row.Size = UDim2.new(1, 0, 0, open and 62 + h + 6 or 62)
                    buildList()
                end
            end)

            function obj:Set(v) sel = v; SelLbl.Text = tostring(v); buildList() end
            function obj:Refresh(opts) options = opts; buildList() end
            return obj
        end

        return tab
    end -- CreateTab

    -- ── Notification ─────────────────────────────
    function W:Notify(cfg2)
        cfg2 = cfg2 or {}
        local notif = F(C.White,
            UDim2.new(0, 272, 0, 0),
            UDim2.new(1, -284, 1, -14), SGui)
        notif.AutomaticSize = Enum.AutomaticSize.Y
        notif.ZIndex        = 300
        corner(10, notif)
        stroke(C.Border, 1.5, notif)
        shadow(notif, 20)
        pad(12, 14, 14, 14, notif)
        vlist(4, notif)

        -- pink top bar
        local bar = F(C.Accent, UDim2.new(1, 0, 0, 3), nil, notif)
        bar.ZIndex = 301; corner(2, bar)

        local tl = L(cfg2.Title or "Notice", Enum.Font.GothamBold, 13, C.TextPri,
            UDim2.new(1, 0, 0, 18), nil, nil, notif)
        tl.ZIndex = 301

        local cl = L(cfg2.Content or "", Enum.Font.Gotham, 11, C.TextSec,
            UDim2.new(1, 0, 0, 0), nil, nil, notif)
        cl.ZIndex      = 301
        cl.TextWrapped = true
        cl.AutomaticSize = Enum.AutomaticSize.Y

        notif.BackgroundTransparency = 1
        tw(notif, { BackgroundTransparency = 0 }, 0.18)
        task.delay(cfg2.Duration or 3.5, function()
            tw(notif, { BackgroundTransparency = 1 }, 0.25)
            task.delay(0.3, function() notif:Destroy() end)
        end)
    end

    return W
end -- CreateWindow

function Library:LoadConfiguration() end
function Library:Destroy() SGui:Destroy() end

return Library
