-- ── Helpers ──────────────────────────────────────────
local function tw(obj, props, t, style)
    TweenService:Create(obj,
        TweenInfo.new(t or 0.14, style or Enum.EasingStyle.Quad), props):Play()
end

local function corner(r, p)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, r)
    c.Parent = p; return c
end

local function stroke(col, thick, p)
    local s = Instance.new("UIStroke")
    s.Color = col or C.Border
    s.Thickness = thick or 1
    s.Parent = p; return s
end

local function pad(t, r, b, l, p)
    local u = Instance.new("UIPadding")
    u.PaddingTop    = UDim.new(0, t or 0)
    u.PaddingRight  = UDim.new(0, r or 0)
    u.PaddingBottom = UDim.new(0, b or 0)
    u.PaddingLeft   = UDim.new(0, l or 0)
    u.Parent = p; return u
end

local function vlist(spacing, p)
    local ul = Instance.new("UIListLayout")
    ul.Padding       = UDim.new(0, spacing or 0)
    ul.FillDirection = Enum.FillDirection.Vertical
    ul.SortOrder     = Enum.SortOrder.LayoutOrder
    ul.Parent = p; return ul
end

local function F(color, size, pos, parent, clip)
    local f = Instance.new("Frame")
    f.BackgroundColor3 = color or C.Card
    f.BorderSizePixel  = 0
    f.Size             = size or UDim2.new(1, 0, 0, 32)
    if pos  then f.Position         = pos  end
    if clip then f.ClipsDescendants = clip end
    f.Parent = parent; return f
end

local function L(text, font, size, color, fsize, pos, xalign, parent)
    local t = Instance.new("TextLabel")
    t.BackgroundTransparency = 1
    t.BorderSizePixel        = 0
    t.Text                   = text  or ""
    t.Font                   = font  or Enum.Font.GothamMedium
    t.TextSize               = size  or 13
    t.TextColor3             = color or C.TextPri
    t.RichText               = true
    t.Size                   = fsize or UDim2.new(1, 0, 1, 0)
    t.TextXAlignment         = xalign or Enum.TextXAlignment.Left
    t.TextYAlignment         = Enum.TextYAlignment.Center
    t.TextTruncate           = Enum.TextTruncate.AtEnd
    if pos then t.Position = pos end
    t.Parent = parent; return t
end

-- ── Shadow ──────────────────────────────────────────
local function shadow(parent, sz)
    local s = Instance.new("ImageLabel")
    s.Size                   = UDim2.new(1, sz or 28, 1, sz or 28)
    s.Position               = UDim2.new(0, -(sz or 28)/2, 0, -(sz or 28)/2 + 3)
    s.BackgroundTransparency = 1
    s.Image                  = "rbxassetid://6014261993"
    s.ImageColor3            = Color3.fromRGB(180, 140, 200)
    s.ImageTransparency      = 0.55
    s.ScaleType              = Enum.ScaleType.Slice
    s.SliceCenter            = Rect.new(49, 49, 450, 450)
    s.ZIndex                 = parent.ZIndex - 1
    s.Parent                 = parent
end

-- ── Context menu ────────────────────────────────────
local CtxMenu = nil
local function closeCtx()
    if CtxMenu then CtxMenu:Destroy(); CtxMenu = nil end
end

local function showCtx(options, ax, ay)
    closeCtx()
    local itemH = 30
    local menuW = 160
    local menuH = #options * itemH + 10

    local menu = F(C.MenuBg,
        UDim2.new(0, menuW, 0, menuH),
        UDim2.new(0, ax, 0, ay), SGui)
    menu.ZIndex = 200
    corner(9, menu)
    stroke(C.Border, 1, menu)
    shadow(menu, 18)
    pad(5, 5, 5, 5, menu)
    vlist(2, menu)
    CtxMenu = menu

    for _, opt in ipairs(options) do
        local row = Instance.new("TextButton")
        row.Size               = UDim2.new(1, 0, 0, itemH - 2)
        row.BackgroundColor3   = opt.active and C.AccentSoft or C.MenuBg
        row.BorderSizePixel    = 0
        row.Text               = ""
        row.ZIndex             = 201
        row.AutoButtonColor    = false
        row.Parent             = menu
        corner(6, row)
        pad(0, 8, 0, 10, row)

        local lbl = L(opt.label, Enum.Font.GothamMedium, 12,
            opt.active and C.Accent or C.TextPri,
            UDim2.new(1, 0, 1, 0), nil, nil, row)
        lbl.ZIndex = 202
        if opt.active then lbl.Font = Enum.Font.GothamBold end

        row.MouseEnter:Connect(function()
            if not opt.active then tw(row, { BackgroundColor3 = C.MenuHover }, 0.08) end
        end)
        row.MouseLeave:Connect(function()
            if not opt.active then tw(row, { BackgroundColor3 = C.MenuBg }, 0.08) end
        end)
        row.MouseButton1Click:Connect(function()
            closeCtx()
            opt.callback()
        end)
    end

    -- close on outside click
    local conn
    conn = UIS.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1
        or i.UserInputType == Enum.UserInputType.MouseButton2 then
            task.defer(function()
                closeCtx()
                if conn then conn:Disconnect() end
            end)
        end
    end)
end

